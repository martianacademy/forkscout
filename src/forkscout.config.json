    "skills": {
        "dirs": [
            ".agents/skills",
            "src/skills/built-in"
        ]
    },
    "n8n": {
        "baseUrl": "http://localhost:5678"
    },
    "embeddings": {
        "enabled": false,
        "provider": "openrouter",
        "model": "openai/text-embedding-3-small",
        "topK": 5,
        "chunkMaxTokens": 500
    },
    "speech": {
        "enabled": true,
        "ttsProvider": "elevenlabs",
        "ttsModel": "eleven_multilingual_v2",
        "ttsVoice": "21m00Tcm4TlvDq8ikWAM",
        "sttProvider": "elevenlabs",
        "sttModel": "scribe_v1",
        "language": "en"
    },
    "imageGeneration": {
        "enabled": true,
        "provider": "openai",
        "model": "dall-e-3",
        "defaultSize": "1024x1024",
        "defaultQuality": "hd",
        "defaultStyle": "vivid"
    }
}